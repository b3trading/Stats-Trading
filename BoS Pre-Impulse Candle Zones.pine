// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@version=6
indicator("BoS Pre-Impulse Candle Zones", overlay=true, max_boxes_count=500)

//──────────────────────────────────────────────────────────────────────────────
// Inputs
//──────────────────────────────────────────────────────────────────────────────
pivotLen  = input.int(5, "Swing Pivot Length", minval=2, group="BoS Detection")
useBody   = input.bool(true, "Zone = Candle Body (not wicks)", group="BoS Detection")
showBoS   = input.bool(true, "Show BoS Markers", group="BoS Detection", tooltip="Triangles where BoS triggers — useful for debugging.")

maxZones       = input.int(15, "Max Zones", minval=1, maxval=100, group="Zone Settings")
invalidateMode = input.string("Freeze", "On Invalidation", options=["Delete", "Freeze"], group="Zone Settings")

baseTrans    = input.int(85, "Zone Transparency", minval=0, maxval=100, group="Visuals")
touchedTrans = input.int(93, "Touched Transparency", minval=0, maxval=100, group="Visuals")
demandColor  = input.color(color.green, "Demand Zone Color", group="Visuals")
supplyColor  = input.color(color.red, "Supply Zone Color", group="Visuals")
borderWidth  = input.int(1, "Border Width", minval=0, maxval=4, group="Visuals")

//──────────────────────────────────────────────────────────────────────────────
// Swing Detection — store candle OHLC at detection time
//──────────────────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float swHi = na
var int   swHiBar = na
var float swHiCandleTop = na
var float swHiCandleBot = na
var bool  swHiUsed = true

var float swLo = na
var int   swLoBar = na
var float swLoCandleTop = na
var float swLoCandleBot = na
var bool  swLoUsed = true

if not na(ph)
    swHi     := ph
    swHiBar  := bar_index - pivotLen
    swHiCandleTop := useBody ? math.max(open[pivotLen], close[pivotLen]) : high[pivotLen]
    swHiCandleBot := useBody ? math.min(open[pivotLen], close[pivotLen]) : low[pivotLen]
    swHiUsed := false

if not na(pl)
    swLo     := pl
    swLoBar  := bar_index - pivotLen
    swLoCandleTop := useBody ? math.max(open[pivotLen], close[pivotLen]) : high[pivotLen]
    swLoCandleBot := useBody ? math.min(open[pivotLen], close[pivotLen]) : low[pivotLen]
    swLoUsed := false

//──────────────────────────────────────────────────────────────────────────────
// BoS — close through swing, fires once per swing
//──────────────────────────────────────────────────────────────────────────────
bullBoS = not swHiUsed and not na(swHi) and close > swHi
bearBoS = not swLoUsed and not na(swLo) and close < swLo

// Debug markers
plotshape(showBoS and bullBoS, "Bull BoS", shape.triangleup, location.belowbar, demandColor, size=size.tiny)
plotshape(showBoS and bearBoS, "Bear BoS", shape.triangledown, location.abovebar, supplyColor, size=size.tiny)

//──────────────────────────────────────────────────────────────────────────────
// Zone Storage
//──────────────────────────────────────────────────────────────────────────────
var array<box>  zoneBoxes   = array.new<box>()
var array<bool> zoneDemand  = array.new<bool>()
var array<bool> zoneActive  = array.new<bool>()
var array<bool> zoneTouched = array.new<bool>()

//──────────────────────────────────────────────────────────────────────────────
// Create zones on BoS
// Bullish BoS → zone at the swing HIGH candle (the level that was broken)
// Bearish BoS → zone at the swing LOW candle (the level that was broken)
//──────────────────────────────────────────────────────────────────────────────
if bullBoS
    swHiUsed := true
    if not na(swHiBar) and not na(swHiCandleTop)
        bx = box.new(swHiBar, swHiCandleTop, bar_index, swHiCandleBot, border_color=demandColor, bgcolor=color.new(demandColor, baseTrans), border_width=borderWidth, extend=extend.right)
        array.push(zoneBoxes, bx)
        array.push(zoneDemand, true)
        array.push(zoneActive, true)
        array.push(zoneTouched, false)

if bearBoS
    swLoUsed := true
    if not na(swLoBar) and not na(swLoCandleTop)
        bx = box.new(swLoBar, swLoCandleTop, bar_index, swLoCandleBot, border_color=supplyColor, bgcolor=color.new(supplyColor, baseTrans), border_width=borderWidth, extend=extend.right)
        array.push(zoneBoxes, bx)
        array.push(zoneDemand, false)
        array.push(zoneActive, true)
        array.push(zoneTouched, false)

// Trim oldest
while array.size(zoneBoxes) > maxZones
    old = array.shift(zoneBoxes)
    array.shift(zoneDemand)
    array.shift(zoneActive)
    array.shift(zoneTouched)
    if not na(old)
        box.delete(old)

//──────────────────────────────────────────────────────────────────────────────
// Update zones: touch = invalidate (stop extending)
//──────────────────────────────────────────────────────────────────────────────
if array.size(zoneBoxes) > 0
    for idx = array.size(zoneBoxes) - 1 to 0
        bx = array.get(zoneBoxes, idx)
        if na(bx)
            array.remove(zoneBoxes, idx)
            array.remove(zoneDemand, idx)
            array.remove(zoneActive, idx)
            array.remove(zoneTouched, idx)
            continue

        if not array.get(zoneActive, idx)
            continue

        topZ   = box.get_top(bx)
        botZ   = box.get_bottom(bx)
        demand = array.get(zoneDemand, idx)

        // Touched = price enters zone (wick or close)
        touched = high >= botZ and low <= topZ

        // Invalidation: close through the zone
        invalid = demand ? (close < botZ) : (close > topZ)

        if invalid or touched
            if invalidateMode == "Delete"
                box.delete(bx)
                array.remove(zoneBoxes, idx)
                array.remove(zoneDemand, idx)
                array.remove(zoneActive, idx)
                array.remove(zoneTouched, idx)
            else
                box.set_right(bx, bar_index)
                box.set_extend(bx, extend.none)
                array.set(zoneActive, idx, false)
