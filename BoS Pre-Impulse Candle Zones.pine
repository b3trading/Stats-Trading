// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@version=6
indicator("BoS Pre-Impulse Candle Zones", overlay=true, max_boxes_count=500)

//──────────────────────────────────────────────────────────────────────────────
// Inputs
//──────────────────────────────────────────────────────────────────────────────
grpBos   = "BoS Detection"
pivotLen  = input.int(10, "Swing Pivot Length", minval=2, group=grpBos, tooltip="Bars left/right for swing detection. Higher = fewer, more significant swings.")
useBody   = input.bool(true, "Zone = Candle Body (not wicks)", group=grpBos, tooltip="ON: zone covers open-to-close (tighter). OFF: zone covers high-to-low (wider).")

grpZone  = "Zone Settings"
extendBars = input.int(200, "Extend Zone Right (bars)", minval=1, maxval=5000, group=grpZone)
maxZones   = input.int(15, "Max Zones", minval=1, maxval=200, group=grpZone)
invalidateMode = input.string("Freeze", "On Invalidation", options=["Delete", "Freeze"], group=grpZone)

grpVisual = "Visuals"
touchRule    = input.string("Wick touch", "Touch Rule (for fade)", options=["Wick touch", "Close inside"], group=grpVisual)
baseTrans    = input.int(85, "Zone Transparency", minval=0, maxval=100, group=grpVisual)
touchedTrans = input.int(93, "Touched Transparency", minval=0, maxval=100, group=grpVisual)
demandColor  = input.color(color.green, "Demand Zone Color", group=grpVisual)
supplyColor  = input.color(color.red, "Supply Zone Color", group=grpVisual)
borderWidth  = input.int(1, "Border Width", minval=0, maxval=4, group=grpVisual)

//──────────────────────────────────────────────────────────────────────────────
// Swing Detection
//──────────────────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float swHi    = na
var int   swHiBar = na
var bool  swHiUsed = true

var float swLo    = na
var int   swLoBar = na
var bool  swLoUsed = true

if not na(ph)
    swHi     := ph
    swHiBar  := bar_index - pivotLen
    swHiUsed := false

if not na(pl)
    swLo     := pl
    swLoBar  := bar_index - pivotLen
    swLoUsed := false

//──────────────────────────────────────────────────────────────────────────────
// BoS — close through swing, fires once per swing
//──────────────────────────────────────────────────────────────────────────────
bullBoS = not swHiUsed and not na(swHi) and close > swHi
bearBoS = not swLoUsed and not na(swLo) and close < swLo

//──────────────────────────────────────────────────────────────────────────────
// Zone Storage
//──────────────────────────────────────────────────────────────────────────────
var array<box>  zoneBoxes   = array.new<box>()
var array<bool> zoneDemand  = array.new<bool>()
var array<bool> zoneActive  = array.new<bool>()
var array<bool> zoneTouched = array.new<bool>()

//──────────────────────────────────────────────────────────────────────────────
// Create zones on BoS
// Bullish BoS → demand zone at the swing low candle
// Bearish BoS → supply zone at the swing high candle
//──────────────────────────────────────────────────────────────────────────────
if bullBoS
    swHiUsed := true
    if not na(swLoBar)
        offset = bar_index - swLoBar
        if offset > 0
            topZ = useBody ? math.max(open[offset], close[offset]) : high[offset]
            botZ = useBody ? math.min(open[offset], close[offset]) : low[offset]
            bx = box.new(swLoBar, topZ, bar_index + extendBars, botZ, border_color=demandColor, bgcolor=color.new(demandColor, baseTrans), border_width=borderWidth)
            array.push(zoneBoxes, bx)
            array.push(zoneDemand, true)
            array.push(zoneActive, true)
            array.push(zoneTouched, false)

if bearBoS
    swLoUsed := true
    if not na(swHiBar)
        offset = bar_index - swHiBar
        if offset > 0
            topZ = useBody ? math.max(open[offset], close[offset]) : high[offset]
            botZ = useBody ? math.min(open[offset], close[offset]) : low[offset]
            bx = box.new(swHiBar, topZ, bar_index + extendBars, botZ, border_color=supplyColor, bgcolor=color.new(supplyColor, baseTrans), border_width=borderWidth)
            array.push(zoneBoxes, bx)
            array.push(zoneDemand, false)
            array.push(zoneActive, true)
            array.push(zoneTouched, false)

// Trim oldest
while array.size(zoneBoxes) > maxZones
    old = array.shift(zoneBoxes)
    array.shift(zoneDemand)
    array.shift(zoneActive)
    array.shift(zoneTouched)
    if not na(old)
        box.delete(old)

//──────────────────────────────────────────────────────────────────────────────
// Update zones: touch fade + close-based invalidation
//──────────────────────────────────────────────────────────────────────────────
if array.size(zoneBoxes) > 0
    for idx = array.size(zoneBoxes) - 1 to 0
        bx = array.get(zoneBoxes, idx)
        if na(bx)
            array.remove(zoneBoxes, idx)
            array.remove(zoneDemand, idx)
            array.remove(zoneActive, idx)
            array.remove(zoneTouched, idx)
            continue

        if not array.get(zoneActive, idx)
            continue

        topZ    = box.get_top(bx)
        botZ    = box.get_bottom(bx)
        demand  = array.get(zoneDemand, idx)
        touched = array.get(zoneTouched, idx)

        // Touch fade
        if not touched
            isTouched = false
            if touchRule == "Wick touch"
                isTouched := high >= botZ and low <= topZ
            else if touchRule == "Close inside"
                isTouched := close <= topZ and close >= botZ
            if isTouched
                c = demand ? demandColor : supplyColor
                box.set_bgcolor(bx, color.new(c, touchedTrans))
                array.set(zoneTouched, idx, true)

        // Invalidation: CLOSE through the zone
        invalid = demand ? (close < botZ) : (close > topZ)

        if invalid
            if invalidateMode == "Delete"
                box.delete(bx)
                array.remove(zoneBoxes, idx)
                array.remove(zoneDemand, idx)
                array.remove(zoneActive, idx)
                array.remove(zoneTouched, idx)
            else
                box.set_right(bx, bar_index)
                array.set(zoneActive, idx, false)
