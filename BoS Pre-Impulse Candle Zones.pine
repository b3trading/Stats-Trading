// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@version=6
indicator("BoS Pre-Impulse Candle Zones", overlay=true, max_boxes_count=500)

//──────────────────────────────────────────────────────────────────────────────
// Inputs
//──────────────────────────────────────────────────────────────────────────────
grpBos   = "BoS Detection"
pivotLen  = input.int(10, "Swing Pivot Length", minval=1, group=grpBos, tooltip="Bars left/right for swing detection. Higher = fewer, more significant swings.")
maxSearch = input.int(20, "Search Back Bars", minval=1, maxval=500, group=grpBos, tooltip="How far back to look for the pre-impulse candle.")
minZonePts = input.float(0, "Min Zone Height (points)", minval=0, group=grpBos, tooltip="Ignore zones smaller than this. 0 = no filter.")

grpZone  = "Zone Settings"
extendBars = input.int(150, "Extend Zone Right (bars)", minval=1, maxval=5000, group=grpZone)
maxZones   = input.int(15, "Max Zones", minval=1, maxval=200, group=grpZone)
invalidateMode = input.string("Freeze", "On Invalidation", options=["Delete", "Freeze"], group=grpZone, tooltip="Delete: remove zone. Freeze: stop extending.")

grpVisual = "Visuals"
touchRule    = input.string("Wick touch", "Touch Rule (for fade)", options=["Wick touch", "Close inside"], group=grpVisual, tooltip="What counts as a 'touch' to fade the zone.")
baseTrans    = input.int(80, "Zone Transparency", minval=0, maxval=100, group=grpVisual)
touchedTrans = input.int(92, "Touched Transparency", minval=0, maxval=100, group=grpVisual)
demandColor  = input.color(color.green, "Demand Zone Color", group=grpVisual)
supplyColor  = input.color(color.red, "Supply Zone Color", group=grpVisual)
borderWidth  = input.int(1, "Border Width", minval=1, maxval=4, group=grpVisual)

//──────────────────────────────────────────────────────────────────────────────
// Swing Detection
//──────────────────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

var float swingHi = na
var float swingLo = na


if not na(ph)
    swingHi := ph

if not na(pl)
    swingLo := pl

// BoS: close through swing level, only if last BoS was opposite side (or first)
// BoS: close crosses through swing level (crossover prevents stale triggers)
bullBoS = not na(swingHi) and close > swingHi and close[1] <= swingHi
bearBoS = not na(swingLo) and close < swingLo and close[1] >= swingLo

//──────────────────────────────────────────────────────────────────────────────
// Zone Storage
//──────────────────────────────────────────────────────────────────────────────
var array<box>  zoneBoxes   = array.new<box>()
var array<bool> zoneDemand  = array.new<bool>()
var array<bool> zoneActive  = array.new<bool>()
var array<bool> zoneTouched = array.new<bool>()

//──────────────────────────────────────────────────────────────────────────────
// Create zones on BoS
//──────────────────────────────────────────────────────────────────────────────
if bullBoS
    int offset = na
    for i = 1 to maxSearch
        if close[i] < open[i]
            offset := i
            break
    if not na(offset)
        topZ = high[offset]
        botZ = low[offset]
        if minZonePts == 0 or (topZ - botZ) >= minZonePts
            c = demandColor
            bx = box.new(bar_index - offset, topZ, bar_index - offset + extendBars, botZ, border_color=c, bgcolor=color.new(c, baseTrans), border_width=borderWidth)
            array.push(zoneBoxes, bx)
            array.push(zoneDemand, true)
            array.push(zoneActive, true)
            array.push(zoneTouched, false)

if bearBoS
    int offset = na
    for i = 1 to maxSearch
        if close[i] > open[i]
            offset := i
            break
    if not na(offset)
        topZ = high[offset]
        botZ = low[offset]
        if minZonePts == 0 or (topZ - botZ) >= minZonePts
            c = supplyColor
            bx = box.new(bar_index - offset, topZ, bar_index - offset + extendBars, botZ, border_color=c, bgcolor=color.new(c, baseTrans), border_width=borderWidth)
            array.push(zoneBoxes, bx)
            array.push(zoneDemand, false)
            array.push(zoneActive, true)
            array.push(zoneTouched, false)

// Trim oldest zones if over limit
while array.size(zoneBoxes) > maxZones
    old = array.shift(zoneBoxes)
    array.shift(zoneDemand)
    array.shift(zoneActive)
    array.shift(zoneTouched)
    if not na(old)
        box.delete(old)

//──────────────────────────────────────────────────────────────────────────────
// Update zones: touch fade + close-based invalidation
//──────────────────────────────────────────────────────────────────────────────
if array.size(zoneBoxes) > 0
    for idx = array.size(zoneBoxes) - 1 to 0
        bx = array.get(zoneBoxes, idx)
        if na(bx)
            array.remove(zoneBoxes, idx)
            array.remove(zoneDemand, idx)
            array.remove(zoneActive, idx)
            array.remove(zoneTouched, idx)
            continue

        if not array.get(zoneActive, idx)
            continue

        topZ    = box.get_top(bx)
        botZ    = box.get_bottom(bx)
        demand  = array.get(zoneDemand, idx)
        touched = array.get(zoneTouched, idx)

        // Touch fade (first touch only)
        if not touched
            isTouched = false
            if touchRule == "Wick touch"
                isTouched := high >= botZ and low <= topZ
            else if touchRule == "Close inside"
                isTouched := close <= topZ and close >= botZ
            if isTouched
                c = demand ? demandColor : supplyColor
                box.set_bgcolor(bx, color.new(c, touchedTrans))
                array.set(zoneTouched, idx, true)

        // Invalidation: CLOSE through the zone
        invalid = demand ? (close < botZ) : (close > topZ)

        if invalid
            if invalidateMode == "Delete"
                box.delete(bx)
                array.remove(zoneBoxes, idx)
                array.remove(zoneDemand, idx)
                array.remove(zoneActive, idx)
                array.remove(zoneTouched, idx)
            else
                box.set_right(bx, bar_index)
                array.set(zoneActive, idx, false)
